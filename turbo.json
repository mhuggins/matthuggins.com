{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false
    },
    "build": {
      "cache": false
    },
    "test": {
      "cache": false
