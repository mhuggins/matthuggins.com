{
  "name": "@matthuggins/chart-builder",
  "version": "1.0.0",
  "description": "Front-end AI agent lab: natural-language weather charts via the Vercel AI SDK",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "types": "src/main.ts",
  "exports": {
    ".": "./src/main.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:lint": "pnpm run lint && pnpm run format && pnpm run typecheck && pnpm run test"
  },
  "keywords": [],
  "author": "Matt Huggins <matt.huggins@gmail.com>",
  "license": "UNLICENSED",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@matthuggins/form": "workspace:*",
    "@matthuggins/ui": "workspace:*",
    "@phosphor-icons/react": "catalog:",
    "ai": "^6.0.196",
    "dedent": "^1.7.1",
    "react-markdown": "^10.1.0",
    "react-vega": "^8.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remeda": "^2.37.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@matthuggins/tsconfig": "workspace:*",
